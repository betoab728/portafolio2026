---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { locale } = Astro.locals;

const {
  title,
  description = "Portafolio de Elias Alegre: desarrollo full stack, sistemas ERP, backend y soluciones empresariales modernas.",
  image = "/assets/og-image.png",
} = Astro.props;

const site = Astro.site?.origin ?? "https://portafolio2026-seven.vercel.app";
const canonicalPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonical = `${site}${canonicalPath}`;

const alternateLocale = locale === "es" ? "en" : "es";
const segments = Astro.url.pathname.split("/").filter(Boolean);
const rest = segments.slice(1).join("/");
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#020a22" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${site}${image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Elias Alegre — Full Stack Software Engineer" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Elias Alegre — Portfolio" />
    <meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
    <meta property="og:locale:alternate" content={locale === "es" ? "en_US" : "es_ES"} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}${image}`} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es" href={`${site}/es${rest ? `/${rest}` : ""}`} />
    <link rel="alternate" hreflang="en" href={`${site}/en${rest ? `/${rest}` : ""}`} />
    <link rel="alternate" hreflang="x-default" href={`${site}/es${rest ? `/${rest}` : ""}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;700&display=swap" rel="stylesheet" />
  </head>

  <body class="font-[Poppins] text-white min-h-screen">
    <slot />
  </body>
</html>
