---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width"
    />

    <title>{title}</title>

    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />

    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="font-[Poppins] bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(2,12,41,0.9),rgba(2,10,34,0.7))] text-white min-h-screen"
  >
    <slot />
  </body>
</html>