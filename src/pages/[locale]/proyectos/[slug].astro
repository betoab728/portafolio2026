---
import type { Locale } from "../../../i18n/config";
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";
import { getProyectos, getProyectoBySlug } from "../../../data/proyectos/loader";
import { getProjects } from "../../../i18n/loader";

export function getStaticPaths() {
  const locales: Locale[] = ["es", "en"];
  const paths: { params: { locale: string; slug: string } }[] = [];

  for (const locale of locales) {
    const proyectos = getProyectos(locale);
    for (const proyecto of proyectos) {
      paths.push({
        params: { locale, slug: proyecto.slug },
      });
    }
  }

  return paths;
}

const { locale: rawLocale, slug } = Astro.params;
const locale = (rawLocale ?? "es") as Locale;
const proyecto = getProyectoBySlug(locale, slug)!;
const t = getProjects(locale);
const capturasGenerales = proyecto.capturas ?? [];
const capturasDesktop = proyecto.capturasDesktop ?? [];
const capturasMobile = proyecto.capturasMobile ?? [];
---

<Layout
  title={`${proyecto.titulo} | Elias Alegre`}
  description={proyecto.descripcion}
>
  <Navbar />

  <main class="min-h-screen">
    <section class="border-b border-white/10 py-20">
      <div class="mx-auto grid max-w-7xl gap-12 px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <a href={`/${locale}/#proyectos`} class="text-sm font-semibold text-yellow-300 transition hover:text-yellow-200">
            {t.detail.back}
          </a>

          <p class="mt-8 text-sm font-semibold uppercase tracking-[0.28em] text-yellow-300/80">
            {proyecto.sector}
          </p>

          <h1 class="mt-4 text-4xl font-bold leading-tight text-white md:text-6xl">
            {proyecto.titulo}
          </h1>

          <p class="mt-6 text-lg leading-9 text-zinc-300">
            {proyecto.descripcion}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {proyecto.demo && (
              <a
                href={proyecto.demo}
                target={proyecto.demo.startsWith("http") ? "_blank" : undefined}
                rel={proyecto.demo.startsWith("http") ? "noreferrer" : undefined}
                class="rounded-lg bg-yellow-300 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-yellow-200 focus:outline-none focus:ring-2 focus:ring-yellow-200 focus:ring-offset-2 focus:ring-offset-slate-950"
              >
                {t.detail.cta.demo}
              </a>
            )}

            {proyecto.github && (
              <a
                href={proyecto.github}
                target="_blank"
                rel="noreferrer"
                class="rounded-lg border border-white/15 px-5 py-3 text-sm font-semibold text-white transition hover:border-white/40"
              >
                {t.detail.cta.code}
              </a>
            )}
          </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-white/10 bg-white/[0.04] shadow-2xl">
          <img
            src={proyecto.imagen}
            alt={proyecto.titulo}
            class="h-full min-h-72 w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="mx-auto grid max-w-7xl gap-8 px-6 lg:grid-cols-[0.8fr_1.2fr]">
        <aside class="card-gold p-6">
          <h2 class="text-xl font-semibold text-white">{t.detail.stack}</h2>
          <div class="mt-5 flex flex-wrap gap-2">
            {proyecto.tecnologias.map((tecnologia) => (
              <span class="rounded-full border border-yellow-300/20 bg-yellow-300/10 px-3 py-1 text-sm text-yellow-100">
                {tecnologia}
              </span>
            ))}
          </div>
        </aside>

        <div class="card-gold p-6">
          <h2 class="text-xl font-semibold text-white">{t.detail.features}</h2>
          <ul class="mt-5 grid gap-3 md:grid-cols-2">
            {proyecto.caracteristicas.map((caracteristica) => (
              <li class="rounded-lg border border-white/10 bg-slate-950/35 px-4 py-3 text-sm leading-6 text-zinc-200">
                {caracteristica}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {proyecto.arquitectura && (
      <section class="pb-16">
        <div class="mx-auto max-w-7xl px-6">
          <div class="mb-8 flex flex-col justify-between gap-3 md:flex-row md:items-end">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.28em] text-yellow-300/80">
                {t.detail.architecture}
              </p>
              <h2 class="mt-3 text-3xl font-bold text-white">{t.detail.architectureHeading}</h2>
            </div>
            <p class="max-w-2xl text-sm leading-7 text-zinc-400">
              {t.detail.architectureDescription}
            </p>
          </div>

          <div class="card-gold p-5 md:p-6">
            <div class="grid gap-4 md:grid-cols-5">
              {proyecto.arquitectura.map((item, index) => (
                <article class="relative rounded-lg border border-white/10 bg-slate-950/35 p-4">
                  <div class="flex h-11 w-11 items-center justify-center rounded-lg border border-yellow-300/25 bg-yellow-300/10 text-sm font-bold text-yellow-100 shadow-[0_0_22px_rgba(201,183,24,0.18)]">
                    {String(index + 1).padStart(2, "0")}
                  </div>
                  <p class="mt-4 text-xs font-semibold uppercase tracking-[0.18em] text-yellow-300/80">
                    {item.tecnologia}
                  </p>
                  <h3 class="mt-2 text-lg font-semibold leading-snug text-white">
                    {item.titulo}
                  </h3>
                  <p class="mt-3 text-sm leading-6 text-zinc-300">
                    {item.descripcion}
                  </p>
                  {index < proyecto.arquitectura.length - 1 && (
                    <div class="pointer-events-none absolute -right-3 top-9 hidden h-px w-6 bg-yellow-300/45 md:block"></div>
                  )}
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    {proyecto.video && (
      <section class="pb-16">
        <div class="mx-auto max-w-7xl px-6">
          <div class="rounded-lg border border-white/10 bg-white/[0.04] p-4 shadow-2xl">
            <div class="mb-4 flex items-center justify-between gap-4 px-2 pt-2">
              <h2 class="text-xl font-semibold text-white">{t.detail.demoHeading}</h2>
              <span class="text-sm text-zinc-400">HTML5</span>
            </div>
            <video
              controls
              preload="metadata"
              class="aspect-video w-full rounded-lg bg-black"
              aria-label={`${t.detail.demoAriaPrefix} ${proyecto.titulo}`}
            >
              <source src={proyecto.video} type="video/mp4" />
              {t.detail.videoFallback}
            </video>
          </div>
        </div>
      </section>
    )}

    <section class="pb-16">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-8 flex flex-col justify-between gap-3 md:flex-row md:items-end">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-yellow-300/80">
              {t.detail.screenshots}
            </p>
            <h2 class="mt-3 text-3xl font-bold text-white">{t.detail.screenshotsHeading}</h2>
          </div>
          <p class="max-w-2xl text-sm leading-7 text-zinc-400">
            {t.detail.screenshotsDescription}
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          {capturasGenerales.map((captura) => (
            <figure class="card-gold overflow-hidden">
              <img
                src={captura.src}
                alt={captura.alt}
                loading="lazy"
                decoding="async"
                class="aspect-video w-full object-cover"
              />
              <figcaption class="border-t border-white/10 px-4 py-3 text-sm text-zinc-400">
                {captura.alt}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    {(capturasDesktop.length > 0 || capturasMobile.length > 0) && (
      <section class="pb-16">
        <div class="mx-auto max-w-7xl px-6">
          <div class="grid gap-6 lg:grid-cols-[1.35fr_0.65fr]">
            {capturasDesktop.length > 0 && (
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.24em] text-yellow-300/80">
                  {t.detail.desktopScreenshots}
                </p>
                <div class="mt-5 grid gap-5">
                  {capturasDesktop.map((captura) => (
                    <figure class="card-gold overflow-hidden">
                      <img
                        src={captura.src}
                        alt={captura.alt}
                        loading="lazy"
                        decoding="async"
                        class="aspect-video w-full object-cover"
                      />
                      <figcaption class="border-t border-white/10 px-4 py-3 text-sm text-zinc-400">
                        {captura.alt}
                      </figcaption>
                    </figure>
                  ))}
                </div>
              </div>
            )}

            {capturasMobile.length > 0 && (
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.24em] text-yellow-300/80">
                  {t.detail.mobileScreenshots}
                </p>
                <div class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-1">
                  {capturasMobile.map((captura) => (
                    <figure class="card-gold overflow-hidden">
                      <img
                        src={captura.src}
                        alt={captura.alt}
                        loading="lazy"
                        decoding="async"
                        class="aspect-[9/16] w-full object-cover"
                      />
                      <figcaption class="border-t border-white/10 px-4 py-3 text-sm text-zinc-400">
                        {captura.alt}
                      </figcaption>
                    </figure>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <section class="pb-24">
      <div class="mx-auto max-w-7xl px-6">
        <div class="card-gold p-6 md:p-8">
          <h2 class="text-2xl font-semibold text-white">{t.detail.challenges}</h2>
          <p class="mt-4 text-base leading-8 text-zinc-300">
            {proyecto.retos}
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
