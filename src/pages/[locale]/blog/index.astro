---
import type { Locale } from "../../../i18n/config";
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import BlogCard from "../../../components/blog/BlogCard.astro";
import { getPosts } from "../../../data/posts/loader";
import { getBlog } from "../../../i18n/loader";

export async function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "en" } },
  ];
}

const { locale } = Astro.params as { locale: Locale };
const posts = await getPosts(locale);
const t = getBlog(locale);
---

<Layout title="Blog">
  <Navbar />
  <section class="py-24">
    <div class="mx-auto max-w-5xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xl font-semibold uppercase tracking-[0.28em] text-yellow-300">
          {t.eyebrow}
        </p>
        <h1 class="mt-4 text-4xl font-bold leading-tight text-white md:text-5xl">
          {t.heading}
        </h1>
        <p class="mt-5 text-base leading-8 text-zinc-300 md:text-lg">
          {t.description}
        </p>
      </div>

      {posts.length === 0 ? (
        <p class="mt-12 text-center text-zinc-400">{t.emptyState}</p>
      ) : (
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {posts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
