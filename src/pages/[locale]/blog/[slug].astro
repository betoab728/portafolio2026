---
import type { Locale } from "../../../i18n/config";
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import { getPosts, getPostBySlug, getTranslatedSlug } from "../../../data/posts/loader";
import { getBlog } from "../../../i18n/loader";
import { renderPostContent } from "../../../lib/renderPostContent";

export async function getStaticPaths() {
  const locales: Locale[] = ["es", "en"];
  const paths: { params: { locale: string; slug: string } }[] = [];

  for (const locale of locales) {
    const posts = await getPosts(locale);
    for (const post of posts) {
      paths.push({ params: { locale, slug: post.slug } });
    }
  }

  return paths;
}

const { locale, slug } = Astro.params as { locale: Locale; slug: string };
const post = await getPostBySlug(locale, slug);
const t = getBlog(locale);

if (!post) {
  return Astro.rewrite(`/${locale}/404`);
}

const contentHtml = renderPostContent(post.content);

const alternateLocale: Locale = locale === "es" ? "en" : "es";
const translatedSlug = await getTranslatedSlug(post.translationGroup, alternateLocale);
const alternateUrls: Record<Locale, string | null> = {
  es: locale === "es" ? `/${locale}/blog/${post.slug}` : (translatedSlug ? `/es/blog/${translatedSlug}` : null),
  en: locale === "en" ? `/${locale}/blog/${post.slug}` : (translatedSlug ? `/en/blog/${translatedSlug}` : null),
};
---
<Layout title={post.title} description={post.seoDescription ?? post.excerpt ?? undefined} image={post.coverImage ?? undefined} alternateUrls={alternateUrls}>
  <Navbar />
  <article class="py-24">
    <div class="mx-auto max-w-3xl px-6">
      <a
        href={`/${locale}/blog/`}
        class="inline-flex items-center gap-1 text-sm text-yellow-300 transition hover:text-yellow-200"
      >
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6" />
        </svg>
        {t.cta.backToBlog}
      </a>

      <h1 class="mt-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        {post.title}
      </h1>

      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-zinc-500">
        {post.publishedAt && (
          <span>{t.dateLabel} {new Date(post.publishedAt).toLocaleDateString(locale === "es" ? "es-PE" : "en-US", { day: "2-digit", month: "short", year: "numeric" })}</span>
        )}
        {post.readingTime != null && (
          <span>{post.readingTime} {t.readingTimeLabel}</span>
        )}
      </div>

      <div
        class="prose prose-invert prose-yellow mt-10 max-w-none"
      >
        <Fragment set:html={contentHtml} />
      </div>
    </div>
  </article>
</Layout>
