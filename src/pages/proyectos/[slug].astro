---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { proyectos } from "../../data/proyectos";

export function getStaticPaths() {
  return proyectos.map((proyecto) => ({
    params: { slug: proyecto.slug },
    props: { proyecto },
  }));
}

const { proyecto } = Astro.props;
---

<Layout
  title={`${proyecto.titulo} | Elias Alegre`}
  description={proyecto.descripcion}
>
  <Navbar />

  <main class="min-h-screen">
    <section class="border-b border-white/10 py-20">
      <div class="mx-auto grid max-w-7xl gap-12 px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <a href="/#proyectos" class="text-sm font-semibold text-yellow-300 transition hover:text-yellow-200">
            Volver a proyectos
          </a>

          <p class="mt-8 text-sm font-semibold uppercase tracking-[0.28em] text-yellow-300/80">
            {proyecto.sector}
          </p>

          <h1 class="mt-4 text-4xl font-bold leading-tight text-white md:text-6xl">
            {proyecto.titulo}
          </h1>

          <p class="mt-6 text-lg leading-9 text-zinc-300">
            {proyecto.descripcion}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {proyecto.demo && (
              <a
                href={proyecto.demo}
                target={proyecto.demo.startsWith("http") ? "_blank" : undefined}
                rel={proyecto.demo.startsWith("http") ? "noreferrer" : undefined}
                class="rounded-lg bg-yellow-300 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-yellow-200 focus:outline-none focus:ring-2 focus:ring-yellow-200 focus:ring-offset-2 focus:ring-offset-slate-950"
              >
                Ver demo
              </a>
            )}

            {proyecto.github && (
              <a
                href={proyecto.github}
                target="_blank"
                rel="noreferrer"
                class="rounded-lg border border-white/15 px-5 py-3 text-sm font-semibold text-white transition hover:border-white/40"
              >
                Ver codigo
              </a>
            )}
          </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-white/10 bg-white/[0.04] shadow-2xl">
          <img
            src={proyecto.imagen}
            alt={proyecto.titulo}
            class="h-full min-h-72 w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="mx-auto grid max-w-7xl gap-8 px-6 lg:grid-cols-[0.8fr_1.2fr]">
        <aside class="rounded-lg border border-white/10 bg-white/[0.04] p-6">
          <h2 class="text-xl font-semibold text-white">Stack tecnico</h2>
          <div class="mt-5 flex flex-wrap gap-2">
            {proyecto.tecnologias.map((tecnologia) => (
              <span class="rounded-full border border-yellow-300/20 bg-yellow-300/10 px-3 py-1 text-sm text-yellow-100">
                {tecnologia}
              </span>
            ))}
          </div>
        </aside>

        <div class="rounded-lg border border-white/10 bg-white/[0.04] p-6">
          <h2 class="text-xl font-semibold text-white">Caracteristicas principales</h2>
          <ul class="mt-5 grid gap-3 md:grid-cols-2">
            {proyecto.caracteristicas.map((caracteristica) => (
              <li class="rounded-lg border border-white/10 bg-slate-950/35 px-4 py-3 text-sm leading-6 text-zinc-200">
                {caracteristica}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {proyecto.video && (
      <section class="pb-16">
        <div class="mx-auto max-w-7xl px-6">
          <div class="rounded-lg border border-white/10 bg-white/[0.04] p-4 shadow-2xl">
            <div class="mb-4 flex items-center justify-between gap-4 px-2 pt-2">
              <h2 class="text-xl font-semibold text-white">Demo en video</h2>
              <span class="text-sm text-zinc-400">HTML5</span>
            </div>
            <video
              controls
              preload="metadata"
              class="aspect-video w-full rounded-lg bg-black"
              aria-label={`Demo en video de ${proyecto.titulo}`}
            >
              <source src={proyecto.video} type="video/mp4" />
              Tu navegador no soporta la reproduccion de videos.
            </video>
          </div>
        </div>
      </section>
    )}

    <section class="pb-16">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-8 flex flex-col justify-between gap-3 md:flex-row md:items-end">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-yellow-300/80">
              Capturas
            </p>
            <h2 class="mt-3 text-3xl font-bold text-white">Vistas del sistema</h2>
          </div>
          <p class="max-w-2xl text-sm leading-7 text-zinc-400">
            Recursos migrados desde la vista detalle original y preparados como galeria estatica para despliegue en Vercel.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          {proyecto.capturas.map((captura) => (
            <figure class="overflow-hidden rounded-lg border border-white/10 bg-white/[0.04]">
              <img
                src={captura.src}
                alt={captura.alt}
                loading="lazy"
                decoding="async"
                class="aspect-video w-full object-cover"
              />
              <figcaption class="border-t border-white/10 px-4 py-3 text-sm text-zinc-400">
                {captura.alt}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="pb-24">
      <div class="mx-auto max-w-7xl px-6">
        <div class="rounded-lg border border-white/10 bg-white/[0.04] p-6 md:p-8">
          <h2 class="text-2xl font-semibold text-white">Retos y solucion</h2>
          <p class="mt-4 text-base leading-8 text-zinc-300">
            {proyecto.retos}
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
