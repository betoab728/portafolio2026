---
import { getNavbar } from "../i18n/loader";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const { locale } = Astro.locals;
const nav = getNavbar(locale);

const navItems = [
  { label: nav.home, href: "/#inicio" },
  { label: nav.skills, href: "/#conocimientos" },
  { label: nav.projects, href: "/#proyectos" },
  { label: nav.experience, href: "/#experiencia" },
  { label: nav.about, href: "/#sobre-mi" },
];
---

<header
  id="site-navbar"
  class="fixed inset-x-0 top-0 z-50 hidden border-b border-white/10 bg-black/35 backdrop-blur-md shadow-[0_0_26px_rgba(201,183,24,0.08)] transition-transform duration-300 ease-out md:block md:translate-y-0"
>
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4"
    aria-label={nav.aria.mainNav}
  >
    <a
      href="/#inicio"
      class="text-xl font-bold text-white transition-colors hover:text-yellow-300"
      data-nav-link
    >
      {nav.brand}
    </a>

    <ul class="hidden items-center gap-8 text-sm md:flex">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-zinc-200 transition-colors hover:text-yellow-300 focus:outline-none focus:ring-2 focus:ring-yellow-300/70 focus:ring-offset-2 focus:ring-offset-black"
          >
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <LanguageSwitcher />
      </li>
    </ul>
  </nav>
</header>

<div class="fixed inset-x-0 top-0 z-50 flex items-center justify-between border-b border-white/10 bg-black/35 px-4 py-3 backdrop-blur-md md:hidden">
  <a
    href="/#inicio"
    class="text-lg font-bold text-white"
    data-nav-link
  >
    {nav.brand}
  </a>
  <div class="flex items-center gap-3">
    <LanguageSwitcher />
    <button
      id="mobile-menu-button"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-lg border border-yellow-300/25 bg-black/70 text-yellow-100 shadow-[0_0_24px_rgba(201,183,24,0.22)] backdrop-blur-md transition duration-300 hover:border-yellow-300/45 hover:bg-black/80 focus:outline-none focus:ring-2 focus:ring-yellow-300/70 focus:ring-offset-2 focus:ring-offset-black"
      aria-label={nav.aria.openMenu}
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="sr-only">{nav.aria.menu}</span>
      <svg
        class="h-5 w-5 transition duration-300"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path data-menu-icon-line d="M4 7h16" />
        <path data-menu-icon-line d="M4 12h16" />
        <path data-menu-icon-line d="M4 17h16" />
      </svg>
    </button>
  </div>
</div>

<div
  id="mobile-menu"
  class="fixed inset-x-4 top-20 z-[55] hidden rounded-lg border border-yellow-300/20 bg-black/85 p-3 shadow-[0_0_34px_rgba(201,183,24,0.18)] backdrop-blur-xl md:hidden"
>
  <ul class="grid gap-1 text-sm" aria-label={nav.aria.mobileMenu}>
    {navItems.map((item) => (
      <li>
        <a
          href={item.href}
          data-mobile-nav-link
          class="block rounded-lg px-4 py-3 font-semibold text-zinc-100 transition hover:bg-yellow-300/10 hover:text-yellow-200 focus:outline-none focus:ring-2 focus:ring-yellow-300/70"
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</div>

<script define:vars={{ ariaOpen: nav.aria.openMenu, ariaClose: nav.aria.closeMenu }}>
  const navbar = document.getElementById("site-navbar");
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");
  const links = document.querySelectorAll("[data-mobile-nav-link]");

  let isMenuOpen = false;

  const setMenuState = (open) => {
    isMenuOpen = open;
    button?.setAttribute("aria-expanded", String(open));
    button?.setAttribute("aria-label", open ? ariaClose : ariaOpen);
    menu?.classList.toggle("hidden", !open);
  };

  button?.addEventListener("click", () => {
    setMenuState(!isMenuOpen);
  });

  links.forEach((link) => {
    link.addEventListener("click", () => setMenuState(false));
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenuState(false);
  });

  window.matchMedia("(min-width: 768px)").addEventListener("change", () => {
    setMenuState(false);
    navbar?.classList.remove("-translate-y-full");
    navbar?.classList.add("translate-y-0");
  });
</script>
