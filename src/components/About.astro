---
import { getAbout } from "../i18n/loader";

const { locale } = Astro.locals;
const about = getAbout(locale);
---

<section id="sobre-mi" class="py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="group">
      <div class="card-gold p-8 md:p-10 lg:relative lg:pr-64">
        <p class="text-xl font-semibold uppercase tracking-[0.28em] text-yellow-300">
          {about.eyebrow}
        </p>
        <h2 class="mt-4 text-4xl font-bold leading-tight text-white md:text-5xl">
          {about.title}
        </h2>

        <div
          class="relative z-10 mx-auto my-8 w-40 overflow-hidden px-2 pt-2 pb-0 sm:w-48 card-gold bg-black/90! transition duration-500 ease-out lg:absolute lg:right-6 lg:top-0 lg:my-0 lg:w-52 lg:-translate-y-[28%]"
        >
          <img
            src="/assets/mifotosinfondo.png"
            alt="Elias Alegre"
            class="block w-full origin-bottom object-contain object-bottom drop-shadow-[0_0_15px_rgba(245,158,11,0.5)] transition-transform duration-500 ease-out group-hover:scale-[1.02]"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="space-y-5 text-sm leading-8 text-zinc-300 md:text-base lg:mt-6">
          {about.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
  </div>
</section>
