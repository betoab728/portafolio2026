---
import type { Tecnologia } from "../types/tecnologia";

interface Props {
  tecnologia: Tecnologia;
}

const { tecnologia } = Astro.props;
---

<div class="flex flex-col items-center gap-2">
  <img
    src={tecnologia.icono}
    alt={tecnologia.nombre}
    class="h-14 w-auto object-contain transition duration-300 hover:scale-110"
  />
  <span class="text-sm text-gray-400">{tecnologia.nombre}</span>
</div>
