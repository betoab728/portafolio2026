---
import { getContact } from "../i18n/loader";

const { locale } = Astro.locals;
const contact = getContact(locale);

const EMAIL = "albertoalegrebarazorda@gmail.com";
const WHATSAPP_NUMBER = "51935185330";
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}`;
---

<section id="contacto" class="py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xl font-semibold uppercase tracking-[0.28em] text-yellow-300">
        {contact.eyebrow}
      </p>
      <h2 class="mt-4 text-4xl font-bold leading-tight text-white md:text-5xl">
        {contact.title}
      </h2>
      <p class="mt-5 text-base leading-8 text-zinc-300 md:text-lg">
        {contact.description}
      </p>
    </div>

    <div class="mx-auto mt-12 grid max-w-3xl gap-4 sm:grid-cols-2">
      <a
        href={`mailto:${EMAIL}`}
        class="card-gold group flex flex-col gap-4 p-6"
        aria-label={contact.aria.email}
      >
        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg border border-yellow-300/25 bg-yellow-300/10 text-yellow-200 shadow-[0_0_22px_rgba(201,183,24,0.16)]">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            class="h-5 w-5 transition duration-300 group-hover:scale-110"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="m3 7 9 6 9-6" />
          </svg>
        </span>
        <span class="min-w-0">
          <span class="block text-sm font-semibold uppercase tracking-[0.22em] text-yellow-300/80">
            {contact.emailLabel}
          </span>
          <span class="mt-1 block text-sm text-zinc-200 md:text-base">
            {contact.emailText}
          </span>
        </span>
      </a>

      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noreferrer"
        class="card-gold group flex flex-col gap-4 p-6"
        aria-label={contact.aria.whatsapp}
      >
        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg border border-yellow-300/25 bg-yellow-300/10 text-yellow-200 shadow-[0_0_22px_rgba(201,183,24,0.16)]">
          <svg
            viewBox="0 0 24 24"
            aria-hidden="true"
            class="h-5 w-5 transition duration-300 group-hover:scale-110"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 11.5a8.5 8.5 0 0 1-12.75 7.36L3 20.5l1.67-5.02A8.5 8.5 0 1 1 21 11.5Z" />
          </svg>
        </span>
        <span class="min-w-0">
          <span class="block text-sm font-semibold uppercase tracking-[0.22em] text-yellow-300/80">
            {contact.whatsappLabel}
          </span>
          <span class="mt-1 block text-sm text-zinc-200 md:text-base">
            {contact.whatsappText}
          </span>
        </span>
      </a>
    </div>
  </div>
</section>
