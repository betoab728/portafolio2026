---
import type { Post } from "../../types/post";
import { getBlog } from "../../i18n/loader";

interface Props {
  post: Post;
}

const { locale } = Astro.locals;
const t = getBlog(locale);
const { post } = Astro.props;
---

<article class="card-gold group flex flex-col overflow-hidden">
  <a
    href={`/${locale}/blog/${post.slug}/`}
    class="flex flex-1 flex-col p-6"
  >
    <h3 class="text-[1.35rem] font-semibold leading-snug text-white transition group-hover:text-yellow-300">
      {post.title}
    </h3>

    {post.excerpt && (
      <p class="mt-4 flex-1 text-sm leading-7 text-zinc-300">
        {post.excerpt}
      </p>
    )}

    <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-zinc-500">
      {post.publishedAt && (
        <span>{t.dateLabel} {new Date(post.publishedAt).toLocaleDateString(locale === "es" ? "es-PE" : "en-US", { day: "2-digit", month: "short", year: "numeric" })}</span>
      )}
      {post.readingTime != null && (
        <span>{post.readingTime} {t.readingTimeLabel}</span>
      )}
    </div>
  </a>

  <div class="px-6 pb-6">
    <a
      href={`/${locale}/blog/${post.slug}/`}
      class="inline-flex items-center justify-center rounded-lg bg-yellow-300 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-yellow-200 focus:outline-none focus:ring-2 focus:ring-yellow-200 focus:ring-offset-2 focus:ring-offset-black"
    >
      {t.cta.readMore}
    </a>
  </div>
</article>
