---
import { getEducation } from "../i18n/loader";

const { locale } = Astro.locals;
const education = getEducation(locale);
---

<section
  id="formacion"
  class="py-24"
>
  <div class="max-w-5xl mx-auto px-6">
    
    <h2
      class="text-4xl font-bold text-center mb-16"
    >
      {education.heading}
    </h2>

    <div class="space-y-8">

      {education.degrees.map((degree) => (
        <div class="card-gold p-8">
          <h3 class="text-2xl font-semibold">
            {degree.title}
          </h3>

          <p class="text-yellow-400 mt-2">
            {degree.institution}
          </p>

          <p class="text-zinc-400 mt-3">
            {degree.period}
          </p>
        </div>
      ))}

    </div>

    <div class="mt-12 text-center">
      <a
        href="https://drive.google.com/drive/folders/1Xo9uXl15c3TqSs2tQ-dYCuW_tFK2l2wx"
        target="_blank"
        class="inline-flex items-center px-6 py-3 rounded-xl bg-yellow-400 text-black font-semibold hover:scale-105 transition-transform"
      >
        {education.cta}
      </a>
    </div>

  </div>
</section>
