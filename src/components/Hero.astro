---
import { getHero } from "../i18n/loader";

const { locale } = Astro.locals;
const hero = getHero(locale);
---

<section
  id="inicio"
  class="flex min-h-[100svh] items-center px-6 py-8 md:min-h-screen md:py-20"
>
  <div class="mx-auto grid w-full max-w-7xl gap-6 sm:gap-8 md:grid-cols-[1.08fr_0.92fr] md:items-center md:gap-x-12 md:gap-y-8 lg:gap-x-16">
    <div class="order-1 md:col-start-1 md:row-start-1">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-yellow-300 md:text-base">
        {hero.subtitle}
      </p>

      <h1 class="mt-3 text-4xl font-bold leading-tight text-white sm:text-5xl md:mt-4 md:text-7xl">
        {hero.title}
      </h1>

      <p class="mt-4 max-w-2xl text-sm leading-7 text-zinc-300 sm:text-base md:mt-6 md:text-lg md:leading-relaxed">
       {hero.description}
      </p>
    </div>

    <div class="order-2 flex justify-center md:col-start-2 md:row-span-2 md:row-start-1">
      <div class="relative">
        <div class="absolute inset-0 rounded-full bg-yellow-300/10 blur-2xl"></div>
        <img
          src="/assets/profile.jpg"
          alt={hero.alt}
          class="relative h-36 w-36 rounded-full border-4 border-white/15 object-cover shadow-2xl sm:h-44 sm:w-44 md:h-72 md:w-72"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>

    <div class="order-3 md:col-start-1 md:row-start-2">
      <div class="flex flex-wrap justify-center gap-4 text-sm sm:gap-6 md:justify-start">
        <a
          href="mailto:albertoalegrebarazorda@gmail.com"
          class="text-zinc-300 transition-colors hover:text-yellow-300"
        >
          {hero.social.gmail}
        </a>

        <a
          href="https://www.linkedin.com/"
          target="_blank"
          rel="noreferrer"
          class="text-zinc-300 transition-colors hover:text-yellow-300"
        >
          {hero.social.linkedin}
        </a>

        <a
          href="https://github.com/betoab728"
          target="_blank"
          rel="noreferrer"
          class="text-zinc-300 transition-colors hover:text-yellow-300"
        >
          {hero.social.github}
        </a>
      </div>

      <div class="mt-5 flex flex-wrap justify-center gap-3 md:mt-7 md:justify-start">
        <a
          href="#proyectos"
          class="inline-flex items-center justify-center rounded-lg bg-yellow-400 px-5 py-2.5 text-sm font-semibold text-black transition-transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-yellow-300/80 focus:ring-offset-2 focus:ring-offset-black md:px-6 md:py-3"
        >
          {hero.cta}
        </a>
      </div>
    </div>
  </div>
</section>
