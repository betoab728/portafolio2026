---
import ProjectCard from "./ProjectCard.astro";
import { getProyectos } from "../../data/proyectos/loader";
import { getProjects } from "../../i18n/loader";

const { locale } = Astro.locals;
const t = getProjects(locale);
const proyectos = getProyectos(locale);
---

<section id="proyectos" class="relative py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xl font-semibold uppercase tracking-[0.28em] text-yellow-300">
        {t.eyebrow}
      </p>
      <h2 class="mt-4 text-4xl font-bold leading-tight text-white md:text-5xl">
        {t.heading}
      </h2>
      <p class="mt-5 text-base leading-8 text-zinc-300 md:text-lg">
        {t.description}
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {proyectos.map((proyecto, index) => (
        <div >
          <ProjectCard proyecto={proyecto} principal={index === 0} />
        </div>
      ))}
    </div>
  </div>
</section>
