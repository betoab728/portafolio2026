---
import type { Proyecto } from "../../types/proyecto";
import { getProjects } from "../../i18n/loader";

interface Props {
  proyecto: Proyecto;
  principal?: boolean;
}

const { locale } = Astro.locals;
const t = getProjects(locale);
const { proyecto, principal = false } = Astro.props;
---

<article
  class="card-gold group relative flex h-full flex-col overflow-hidden"
>
  <a href={`/${locale}/proyectos/${proyecto.slug}`} class="block" aria-label={`${t.aria.detailPrefix} ${proyecto.titulo}`}>
    <div class="relative aspect-[16/10] overflow-hidden bg-slate-950">
      <img
        src={proyecto.imagen}
        alt={proyecto.titulo}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
      {(proyecto.destacado || principal) && (
        <span class="absolute left-4 top-4 rounded-full border border-yellow-300/40 bg-yellow-300/15 px-3 py-1 text-xs font-semibold text-yellow-200 backdrop-blur">
          {principal ? t.badge.principal : t.badge.featured}
        </span>
      )}
    </div>
  </a>

  <div class="flex flex-1 flex-col p-6">
    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-yellow-300/80">
      {proyecto.sector}
    </p>

    <h3 class="mt-3 text-[1.35rem] font-semibold leading-snug text-white">
      <a href={`/${locale}/proyectos/${proyecto.slug}`} class="transition hover:text-yellow-300">
        {proyecto.titulo}
      </a>
    </h3>

    <p class="mt-4 flex-1 text-sm leading-7 text-zinc-300">
      {proyecto.resumen}
    </p>

    <div class="mt-5 flex flex-wrap gap-2" aria-label={t.aria.technologies}>
      {proyecto.tecnologias.slice(0, 5).map((tecnologia) => (
        <span class="rounded-full border border-white/10 bg-white/[0.06] px-3 py-1 text-xs text-zinc-200">
          {tecnologia}
        </span>
      ))}
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href={`/${locale}/proyectos/${proyecto.slug}`}
        class="inline-flex items-center justify-center rounded-lg bg-yellow-300 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-yellow-200 focus:outline-none focus:ring-2 focus:ring-yellow-200 focus:ring-offset-2 focus:ring-offset-slate-950"
      >
        {t.cta.detail}
      </a>

      {proyecto.demo && (
        <a
          href={proyecto.demo}
          target={proyecto.demo.startsWith("http") ? "_blank" : undefined}
          rel={proyecto.demo.startsWith("http") ? "noreferrer" : undefined}
          class="inline-flex items-center justify-center rounded-lg border border-white/15 px-4 py-2 text-sm font-semibold text-white transition hover:border-yellow-300/50 hover:text-yellow-200"
        >
          {t.cta.demo}
        </a>
      )}

      {proyecto.github && (
        <a
          href={proyecto.github}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center rounded-lg border border-white/15 px-4 py-2 text-sm font-semibold text-white transition hover:border-white/40"
        >
          {t.cta.github}
        </a>
      )}
    </div>
  </div>
</article>
