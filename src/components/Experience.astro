---
import { experiencias } from "../data/experiencias";
import ExperienceCard from "./experience/ExperienceCard.astro";
---

<section id="experiencia" class="relative py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xl font-semibold uppercase tracking-[0.28em] text-yellow-300">
        Experiencia Profesional
      </p>
      <h2 class="mt-4 text-4xl font-bold leading-tight text-white md:text-5xl">
        Trayectoria construyendo sistemas
      </h2>
      <p class="mt-5 text-base leading-8 text-zinc-300 md:text-lg">
        Experiencia en software empresarial, ERP, POS, infraestructura y aplicaciones full stack con foco en continuidad operativa, datos y escalabilidad.
      </p>
    </div>

    <div class="relative mx-auto mt-14 max-w-5xl">
      <div class="absolute bottom-0 left-4 top-0 w-px bg-gradient-to-b from-yellow-300/0 via-yellow-300/45 to-yellow-300/0 md:left-6"></div>

      <div class="space-y-6 md:space-y-7">
        {experiencias.map((experiencia) => (
          <ExperienceCard experiencia={experiencia} />
        ))}
      </div>
    </div>
  </div>
</section>
